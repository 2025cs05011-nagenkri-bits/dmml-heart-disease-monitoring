# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
venv/
.venv/
env/
.env

# --- Jupyter ---
.ipynb_checkpoints/
*.nbconvert.ipynb

# --- MLflow local tracking store ---
mlruns/
mlartifacts/

# --- Generated data + models ---
# Train/test splits are reproducible from src/data/prepare.py
DMML_Evidently_Demo/data/processed/*.csv
# Trained models are reproducible from src/training/train.py
DMML_Evidently_Demo/models/*.pkl
# NOTE: DMML_Evidently_Demo/data/reference/ is intentionally NOT ignored.
# It contains frozen training-set snapshots used as drift-detection
# baselines (created via scripts/freeze_reference.py).

# --- Reports artifacts (regenerable) ---
DMML_Evidently_Demo/reports/metrics.json

# --- Evidently AI reports (regenerable from scripts/run_evidently.py) ---
DMML_Evidently_Demo/reports/evidently/*.html
DMML_Evidently_Demo/reports/evidently/*.json
!DMML_Evidently_Demo/reports/evidently/.gitkeep

# --- Drift demo datasets (regenerable from scripts/generate_drift_demo.py) ---
DMML_Evidently_Demo/data/demo/*.csv

# --- Inference log written by the Flask app (Step 5, future) ---
DMML_Evidently_Demo/data/inference_log.csv

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Test / coverage ---
.pytest_cache/
.coverage
htmlcov/

# --- Reference materials (not part of submission) ---
mlops_demo/
Mlops_Assignment1.pdf

